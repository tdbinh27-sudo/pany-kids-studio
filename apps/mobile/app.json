{
  "expo": {
    "name": "Pany Kids Studio",
    "slug": "pany-kids-studio",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFE5F1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.panykids.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFE5F1"
      },
      "package": "io.panykids.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiBaseUrl": "https://pany-kids-studio.vercel.app",
      "eas": {
        "projectId": "TBD-set-after-eas-init"
      }
    },
    "plugins": []
  }
}
